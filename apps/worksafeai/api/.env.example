# ===== ENVIRONMENT =====
NODE_ENV=development
PORT=3000

# ===== DATABASE =====
DATABASE_URL=postgresql://user:password@localhost:5432/worksafeai
DATABASE_POOL_SIZE=10
DATABASE_TIMEOUT=30000

# ===== SECURITY =====
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long-for-production
JWT_EXPIRY=3600
JWT_REFRESH_EXPIRY=604800
BCRYPT_ROUNDS=12

# ===== CORS & ORIGINS =====
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,https://app.worksafeai.com,https://admin.worksafeai.com
ALLOWED_DOMAINS=worksafeai.com,localhost

# ===== EMAIL =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=f5zothoi@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@worksafeai.com
SMTP_FROM_NAME=WorkSafeAI

# ===== AI (ANTHROPIC) =====
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_MAX_TOKENS=500

# ===== STRIPE =====
STRIPE_PUBLIC_KEY=pk_test_xxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxx
STRIPE_WEBHOOK_SECRET=whsec_test_xxxxxx
STRIPE_PRODUCT_ID_STARTER=prod_starter
STRIPE_PRODUCT_ID_PRO=prod_pro
STRIPE_PRODUCT_ID_ENTERPRISE=prod_enterprise

# ===== REDIS (OPTIONAL) =====
REDIS_URL=redis://localhost:6379
REDIS_TIMEOUT=3000
REDIS_MAX_RETRIES=3

# ===== LOGGING =====
LOG_LEVEL=info
LOG_FORMAT=json

# ===== FEATURES =====
ENABLE_EMAIL_VERIFICATION=true
ENABLE_ANALYTICS=true
ENABLE_WEBHOOKS=true
ENABLE_CACHING=true
ENABLE_MIGRATIONS=true

# ===== SUPABASE =====
SUPABASE_URL=https://yajgvdolpynezwlwkvva.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===== SENTRY (ERROR TRACKING) =====
SENTRY_DSN=https://xxx@sentry.io/xxx

# ===== ENVIRONMENT-SPECIFIC =====
# Development
# DATABASE_URL=postgresql://localhost/worksafeai_dev
# NODE_ENV=development
# ENABLE_EMAIL_VERIFICATION=false

# Production
# NODE_ENV=production
# JWT_SECRET=<long-random-string-from-secure-generator>
# DATABASE_URL=<production-database-url>
# ENABLE_EMAIL_VERIFICATION=true
