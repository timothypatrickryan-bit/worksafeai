{
  "name": "jtsa-backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --detectOpenHandles --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "migrate": "node src/cli/migrate.js",
    "migrate:status": "node src/cli/migrate.js status",
    "migrate:list": "node src/cli/migrate.js list",
    "migrate:rollback": "node src/cli/migrate.js rollback"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js",
      "**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/cli/**",
      "!src/db/**"
    ],
    "testTimeout": 10000
  },
  "devDependencies": {
    "dotenv": "^17.3.1",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "supertest": "^6.3.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@supabase/supabase-js": "^2.98.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.1",
    "openai": "^6.27.0",
    "pdfkit": "^0.17.2",
    "redis": "^4.6.12",
    "stripe": "^14.7.0",
    "uuid": "^9.0.0",
    "zod": "^4.3.6"
  }
}
