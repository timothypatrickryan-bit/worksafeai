  "priority_levels": {
    "critical": {
      "level": 1,
      "description": "Security vulnerabilities, production outages, data integrity",
      "examples": [
        "Security exploit found",
        "Production down",
        "Data corruption"
      ],
      "sla_minutes": 15,
      "escalate_to_tim": true
    },
    "high": {
      "level": 2,
      "description": "Feature code ready for review, blocking decisions, architecture",
      "examples": [
        "PR ready for review",
        "Design decision needed",
        "Architecture issue"
      ],
      "sla_minutes": 60,
      "escalate_to_tim": false
    },
    "medium": {
      "level": 3,
      "description": "Design work, documentation, non-urgent code review",
      "examples": [
        "New design proposal",
        "Docs needed",
        "Code review"
      ],
      "sla_minutes": 480,
      "escalate_to_tim": false
    },
    "low": {
      "level": 4,
      "description": "Refactoring, optimization, nice-to-have improvements",
      "examples": [
        "Code cleanup",
        "Performance optimization",
        "UX polish"
      ],
      "sla_minutes": 1440,
      "escalate_to_tim": false
    }
  },
  "routing_rules": {
    "parallel_work": {
      "design_and_dev": {
        "agents": [
          "johnny",
          "jarvis"
        ],
        "condition": "design != complete AND dev != complete",
        "sync_point": "after design"
      },
      "review_and_test": {
        "agents": [
          "opus",
          "velma"
        ],
        "condition": "code complete AND separate concerns",
        "sync_point": "after review"
      }
    },
    "blocking_conditions": {
      "design_blocks_dev": "Johnny's design must be complete before Jarvis starts",
      "review_blocks_merge": "Opus review must pass before code merges",
      "test_blocks_release": "Velma's tests must pass before release",
      "strategy_blocks_action": "Laura's analysis must guide execution"
    }
  }
}