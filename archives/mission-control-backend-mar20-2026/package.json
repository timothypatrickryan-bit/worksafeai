{
  "name": "mission-control-backend",
  "version": "1.0.0",
  "description": "Mission Control backend API - Production-ready with JWT auth, rate limiting, and SQLite",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "npx tsx watch src/index.ts",
    "build": "npx tsc",
    "start": "node dist/index.js",
    "seed": "npx tsx src/scripts/seed.ts",
    "type-check": "npx tsc --noEmit"
  },
  "keywords": [
    "mission-control",
    "api",
    "backend",
    "express",
    "typescript",
    "jwt",
    "sqlite"
  ],
  "author": "Tim Ryan",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "jsonwebtoken": "^9.0.0",
    "sqlite3": "^5.1.6",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.10.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
